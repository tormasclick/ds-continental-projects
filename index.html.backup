    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="DS Continental Projects | Industrial Group">
    <meta name="twitter:description" content="Leading provider of heavy machinery, security solutions, and mineral trading across East and Central Africa.">
    <meta name="twitter:image" content="https://yourdomain.com/twitter-image.jpg">
    
    <!-- Favicon - you'll need to replace this with your company favicon -->
